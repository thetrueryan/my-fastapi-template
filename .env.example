# API Configuration
APP_CONFIG__RUN__HOST=0.0.0.0
APP_CONFIG__RUN__PORT=8000

# Hysteria Configuration
# Name of the Hysteria container to restart on config changes
APP_CONFIG__HYSTERIA__CONTAINER_NAME=hysteria

# Public address for client config generation (hy2://...)
APP_CONFIG__HYSTERIA__PUBLIC_HOST=your-domain.com
APP_CONFIG__HYSTERIA__PUBLIC_PORT=443

# ACME (Let's Encrypt) Configuration for automatic certificate generation
APP_CONFIG__HYSTERIA__ACME_EMAIL=admin@your-domain.com
APP_CONFIG__HYSTERIA__ACME_DOMAIN=your-domain.com

# Hysteria Server Configuration
APP_CONFIG__HYSTERIA__LISTEN_PORT=:443
APP_CONFIG__HYSTERIA__MASQUERADE_URL=https://bing.com
